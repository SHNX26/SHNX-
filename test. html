<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>مختبر ربط البيانات - أسامة</title>
    <style>
        body { font-family: sans-serif; background: #121212; color: white; padding: 20px; }
        .data-card { background: #1e1e1e; border: 1px solid #333; padding: 15px; margin-bottom: 10px; border-radius: 8px; border-right: 4px solid #E50914; }
        .status { font-weight: bold; margin-bottom: 20px; padding: 15px; border-radius: 5px; background: rgba(255, 255, 255, 0.05); }
        .success { color: #4CAF50; border: 1px solid #4CAF50; }
        .error { color: #ff5252; border: 1px solid #ff5252; }
    </style>
</head>
<body>

    <h2>مختبر سحب البيانات 🧪</h2>
    <div id="status" class="status" style="color: #FFC107;">⏳ جاري الاتصال بالسيرفر...</div>
    <div id="output"></div>

    <script>
        // استخدام طريقتك الذكية لتخطي حماية جوجل
        const sheetID = "1UChkTwIZFxkwV0vDepyNcWNe0Gb6eSbpDajdWX5mvOE";
        
        // تم التعديل هنا إلى Sheet1 بناءً على تغييرك
        const sheetName = "Sheet1"; 
        const sheetURL = `https://opensheet.elk.sh/${sheetID}/${sheetName}`;

        async function testConnection() {
            const output = document.getElementById('output');
            const status = document.getElementById('status');

            try {
                const response = await fetch(sheetURL);
                
                if (!response.ok) {
                    throw new Error("فشل الاتصال! تأكد من أن اسم الورقة تحت في الشيت هو Sheet1 تماماً بدون مسافات إضافية.");
                }

                const data = await response.json();
                
                status.innerHTML = "✅ <b>تم سحب البيانات بنجاح! اقتراحك كان في محله.</b>";
                status.className = "status success";
                output.innerHTML = ""; 
                
                // جلب البيانات بناءً على أسماء الأعمدة اللي كتبتها أنت في الشيت
                data.forEach(row => {
                    if (row.series && row.episode && row.link) {
                        const div = document.createElement('div');
                        div.className = "data-card";
                        div.innerHTML = `
                            <strong>المسلسل:</strong> ${row.series} <br><br>
                            <strong>الحلقة:</strong> ${row.episode} <br><br>
                            <strong>الرابط:</strong> <a href="${row.link}" target="_blank" style="color: #2196F3; word-break: break-all;">${row.link}</a>
                        `;
                        output.appendChild(div);
                    }
                });

            } catch (err) {
                status.innerHTML = `❌ <b>حدث خطأ:</b><br><br> ${err.message}`;
                status.className = "status error";
            }
        }

        testConnection();
    </script>
</body>
</html>
