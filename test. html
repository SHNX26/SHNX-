<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>مختبر ربط البيانات - أسامة</title>
    <style>
        body { font-family: sans-serif; background: #121212; color: white; padding: 20px; }
        .data-card { background: #1e1e1e; border: 1px solid #333; padding: 15px; margin-bottom: 10px; border-radius: 8px; }
        .status { color: #4CAF50; font-weight: bold; margin-bottom: 20px; }
        .error { color: #ff5252; }
    </style>
</head>
<body>

    <h2>مختبر سحب بيانات Google Sheets 🧪</h2>
    <div id="status" class="status">جاري الاتصال بجوجل...</div>
    <div id="output"></div>

    <script>
        // رابط ملفك اللي أرسلته لي (بصيغة CSV)
        const sheetURL = "https://docs.google.com/spreadsheets/d/1UChkTwIZFxkwV0vDepyNcWNe0Gb6eSbpDajdWX5mvOE/gviz/tq?tqx=out:csv";

        async function testConnection() {
            const output = document.getElementById('output');
            const status = document.getElementById('status');

            try {
                // 1. طلب البيانات من جوجل
                const response = await fetch(sheetURL);
                
                if (!response.ok) throw new Error("فشل الوصول للملف، تأكد من صلاحيات المشاركة");

                const csvData = await response.text();
                
                // 2. معالجة النص القادم وتحويله لصفوف
                const rows = csvData.split('\n');
                
                status.innerText = "✅ تم سحب البيانات بنجاح! إليك النتائج:";
                
                // 3. عرض البيانات في الصفحة
                output.innerHTML = ""; // تنظيف المكان
                
                rows.forEach((row, index) => {
                    // نتجاهل أول سطر لأنه العنوان (Header)
                    if (index === 0) return;

                    const columns = row.split(',');
                    if (columns.length >= 3) {
                        const div = document.createElement('div');
                        div.className = "data-card";
                        div.innerHTML = `
                            <strong>المسلسل:</strong> ${columns[0]} <br>
                            <strong>الحلقة:</strong> ${columns[1]} <br>
                            <strong>الرابط:</strong> <span style="color: #2196F3;">${columns[2]}</span>
                        `;
                        output.appendChild(div);
                    }
                });

            } catch (err) {
                status.innerText = "❌ حدث خطأ في الاتصال";
                status.className = "status error";
                output.innerHTML = `<p>${err.message}</p>`;
            }
        }

        // تشغيل الاختبار فور فتح الصفحة
        testConnection();
    </script>
</body>
</html>
